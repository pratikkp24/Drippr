# ── Supabase (required for Phase 1) ────────────────────────────
# Create a project at https://supabase.com and copy these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres (required for Phase 1) ────────────────────────────
# Project Settings → Database → Connection string (pooled + direct)
# Pooled (for Prisma Client): add ?pgbouncer=true&connection_limit=1
DATABASE_URL=
# Direct (for Prisma migrations)
DIRECT_URL=

# ── App (required) ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Phase 3+ (add later) ──────────────────────────────────────
MICROLINK_API_KEY=
CUELINKS_API_KEY=
CUELINKS_CID=
RESEND_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
